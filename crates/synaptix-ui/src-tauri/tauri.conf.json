{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synaptix",
  "version": "1.2.0",
  "identifier": "dev.synaptix.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libdbus-1-3", "libusb-1.0-0", "libwebkit2gtk-4.1-0"],
        "files": {
          "/usr/bin/synaptix-daemon": "../../../target/release/synaptix-daemon",
          "/usr/lib/systemd/user/synaptix-daemon.service": "../../../packaging/synaptix-daemon.service",
          "/etc/udev/rules.d/99-synaptix.rules": "../../../packaging/99-synaptix.rules"
        },
        "postInstallScript": "../../../packaging/post_install.sh"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Synaptix",
        "width": 900,
        "height": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
