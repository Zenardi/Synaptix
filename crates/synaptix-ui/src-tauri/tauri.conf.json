{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synaptix",
  "version": "0.1.0",
  "identifier": "dev.synaptix.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": false
  },
  "app": {
    "windows": [
      {
        "title": "Synaptix",
        "width": 900,
        "height": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
