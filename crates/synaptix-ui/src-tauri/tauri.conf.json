{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synaptix",
  "version": "0.1.0",
  "identifier": "dev.synaptix.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [],
    "linux": {
      "deb": {
        "depends": ["libdbus-1-3", "libusb-1.0-0", "libwebkit2gtk-4.1-0"],
        "files": {
          "/usr/bin/synaptix-daemon": "../../target/release/synaptix-daemon",
          "/usr/lib/systemd/system/synaptix-daemon.service": "../../packaging/synaptix-daemon.service",
          "/etc/udev/rules.d/99-synaptix.rules": "../../packaging/99-synaptix.rules"
        },
        "postInstallScript": "../../packaging/post_install.sh"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Synaptix",
        "width": 900,
        "height": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
